# Backend Production Environment Variables
# Copy this to .env on your production server and fill in real values

ACCESS_TOKEN_SECRET=your_access_token_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# Stripe Payment Configuration (LIVE keys for production)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_YOUR_STRIPE_SECRET_KEY_HERE

# Client URL for payment redirects (YOUR PRODUCTION DOMAIN)
CLIENT_URL=https://squarestrat.com

# SendGrid Email Configuration
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.YOUR_SENDGRID_API_KEY_HERE
SENDGRID_FROM_EMAIL=noreply@squarestrat.com
