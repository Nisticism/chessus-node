# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_PORT=3306
DB_NAME=chessusnode

# JWT Secrets (Optional - if not set, secrets will be auto-generated and saved to server/.jwt-secrets.json)
# For production, set these to stable random values (64+ chars recommended)
# Example: openssl rand -hex 64
ACCESS_TOKEN_SECRET=your_jwt_secret_here
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here

# Server Port (optional, defaults to 3001)
PORT=3001

# CORS Configuration (optional, for additional custom origins)
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
